# ═══════════════════════════════════════════════════════════════════
# OMNISEEN — Supabase Edge Functions Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file to supabase/functions/.env for local development
# In production, configure these as Supabase Secrets (Dashboard > Edge Functions > Secrets)
#
# To set all secrets at once in production:
#   supabase secrets set --env-file ./supabase/functions/.env
# ═══════════════════════════════════════════════════════════════════

# ─── Supabase (auto-populated in production, required for local dev) ──────────
SUPABASE_URL=https://oxbrvyinmpbkllicaxqk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── App Base URL ────────────────────────────────────────────────────────────
# DEV:  http://localhost:5173
# PROD: https://app.omniseen.com
APP_URL=http://localhost:5173

# ─── Instagram / Facebook (Meta Developers) ──────────────────────────────────
# Create app at: https://developers.facebook.com/apps/
# Add products: Facebook Login, Instagram Graph API
# Valid OAuth Redirect URI: https://oxbrvyinmpbkllicaxqk.supabase.co/functions/v1/social-oauth-callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── LinkedIn Developers ─────────────────────────────────────────────────────
# Create app at: https://www.linkedin.com/developers/apps/
# Products: Sign In with LinkedIn using OpenID Connect, Share on LinkedIn, Marketing Developer Platform
# Authorized Redirect URL: https://oxbrvyinmpbkllicaxqk.supabase.co/functions/v1/social-oauth-callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Google Cloud Console ────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Enable: Business Profile API, Google My Business API
# Authorized redirect URI: https://oxbrvyinmpbkllicaxqk.supabase.co/functions/v1/social-oauth-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OpenAI (for content generation) ─────────────────────────────────────────
OPENAI_API_KEY=

# ─── Google AI / Gemini / Places ─────────────────────────────────────────────
GOOGLE_API_KEY=AIzaSyBQDbwGm7rT3wu07xkHLBt2Cg0t2YE9OjI
GEMINI_API_KEY=AIzaSyBQDbwGm7rT3wu07xkHLBt2Cg0t2YE9OjI

# ─── Google OAuth (My Business / Social OAuth) ───────────────────────────────
