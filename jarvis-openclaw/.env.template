# Jarvis OS - OpenClaw Sandbox Environment

# 1. PRIMARY SYSTEM 
# Disable Heartbeat temporarily to prevent loop runs before you trust the system
OC_ENABLE_HEARTBEAT=false

# 2. INTELLIGENCE (LLM MULTI-MODEL ROUTING)
# Primary: Volume tasks (Cheaper/Faster)
OC_LLM_PRIMARY_PROVIDER=gemini
OC_LLM_PRIMARY_MODEL=gemini-2.5-flash

# Fallback: Logic / Actions
OC_LLM_FALLBACK_PROVIDER=openai
OC_LLM_FALLBACK_MODEL=gpt-4o-mini

# Premium: On Demand Complex Copywriting
OC_LLM_PREMIUM_PROVIDER=anthropic
OC_LLM_PREMIUM_MODEL=claude-3.5-sonnet-20241022

# API KEYS
OPENAI_API_KEY="sk-proj-YOUR_API_KEY_HERE"
ANTHROPIC_API_KEY="sk-ant-YOUR_API_KEY_HERE"
GEMINI_API_KEY="AIzaSyYOUR_API_KEY_HERE"

# 3. CHANNELS (TELEGRAM BOT)
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_ALLOWED_USERS="YOUR_TELEGRAM_USERNAME"

# 4. MEMORY & STORAGE
OC_WORKSPACE_DIR=/workspace
OC_SKILLS_DIR=/skills
